# Supabase (get these from your project at https://supabase.com/dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# EmailJS (https://www.emailjs.com/)
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
# Notify admin when a visitor submits – template uses {{email}}, {{Admin}}, {{name}}, {{purpose}}, {{host_name}}, {{visit_date}}, {{admin_link}}
VITE_EMAILJS_ADMIN_NOTIFY_TEMPLATE_ID=your_admin_notify_template_id
# Approval email to visitor (when admin approves) – template uses {{email}}, {{name}}, {{purpose}}, {{host_name}}, {{visit_date}}, {{qr_code_url}}
VITE_EMAILJS_ADMIN_NOTIFY_TEMPLATE_ID=your_approval_template_id
